<div
  class="{{ [
    "grid",
    "px-2",
    "mb-10",
    "md:px-5",
    "md:grid-cols-16",
    "md:[&>*]:col-start-6",
    "md:[&>*]:col-span-11",
    "md:[&>div]:col-span-16",
    "md:[&>div]:px-0",
    "md:[&>div]:mt-10",
    "md:[&>blockquote]:col-start-6",
    "md:[&>blockquote]:col-span-10",
    "[&>gallery-carousel]:-mx-2",
    "md:[&>gallery-carousel]:col-start-1",
    "md:[&>gallery-carousel]:col-span-full",
    "md:[&>gallery-carousel]:-mx-5",
    "lg:[&>*]:col-start-8",
    "lg:[&>*]:col-span-8"
  ]|join(" ") }}"
>
  {% include "_rich-text/standard" with {
    text: text
      |retconAutoAlt
      |replace({
        '/<div class="col-xs-24">/': "",
        "/<\/div>$/": ""
      })
  } only %}
</div>
